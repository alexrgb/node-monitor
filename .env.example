# Example environment configuration for Node Monitor
# Copy this file to `.env` and adjust values as needed.
# Lines starting with `#` are comments.

# ---------------------------------------------------
# Server
# ---------------------------------------------------
# HTTP port to listen on (default 3000)
PORT=3000

# CORS allowed origin. Use "*" to allow all origins.
# Examples:
#   CORS_ORIGIN=*
#   CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=*

# ---------------------------------------------------
# Retry settings
# ---------------------------------------------------
# Enable/disable retry on failure
# Accepted truthy: 1,true,yes,y,on (case-insensitive)
# Accepted falsy:  0,false,no,n,off
RETRY_ENABLED=true

# Total attempts INCLUDING the first run (min 1). Default 2 (one retry)
RETRY_MAX_ATTEMPTS=2

# ---------------------------------------------------
# Analytics knobs
# ---------------------------------------------------
# Minutes considered the "cold start" window after app boot
COLD_START_MINUTES=10

# ---------------------------------------------------
# Job simulation timings (bounds applied to computed durations)
# ---------------------------------------------------
# Minimum simulated job duration in milliseconds (min 50ms)
JOB_MIN_MS=300
# Maximum simulated job duration in milliseconds (min 200ms)
JOB_MAX_MS=8000

# ---------------------------------------------------
# Native C++ simulator (optional)
# ---------------------------------------------------
# Absolute path to a compiled native simulator binary.
# If not set, the app will try to auto-detect native/bin/simulator(.exe).
# Example Windows path:
#   NATIVE_SIMULATOR_PATH=C:\\path\\to\\project\\native\\bin\\simulator.exe
# Example Unix/macOS path:
#   NATIVE_SIMULATOR_PATH=/path/to/project/native/bin/simulator
NATIVE_SIMULATOR_PATH=

# ---------------------------------------------------
# Notes
# ---------------------------------------------------
# - The app reads env values via @nestjs/config at startup.
# - To use this file locally, duplicate as ".env" next to package.json.
# - Windows PowerShell: set temps like `$env:PORT=4000; pnpm run dev`.
# - Unix/macOS: `PORT=4000 pnpm run dev`.
