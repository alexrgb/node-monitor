{
  "name": "node-monitor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest-e2e.config.js",
    "build:native:unix": "mkdir -p native/bin && c++ -O2 -std=c++17 native/src/simulator.cpp -o native/bin/simulator",
    "build:native:win": "powershell -NoProfile -Command \"$ErrorActionPreference='Stop'; New-Item -ItemType Directory -Force native/bin > $null; cl /nologo /O2 /std:c++17 native/src/simulator.cpp /Fe:native/bin/simulator.exe\"",
    "bru:run": "pnpm dlx @usebruno/cli bru run --env Local ./bruno",
    "bru:run:ci": "pnpm dlx @usebruno/cli bru run --env Local --bail ./bruno"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/config": "^3.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/supertest": "^2.0.16",
    "@nestjs/testing": "^10.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
